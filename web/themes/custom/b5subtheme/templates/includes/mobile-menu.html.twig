{#
  themes/custom/b5subtheme/templates/includes/mobile-menu.html.twig

  Mobile slide-out menu overlay.

  Uses mobile_menu_items from b5subtheme_preprocess_page() to dynamically
  render the main menu. This ensures mobile menu stays in sync with desktop.
#}

<div
  id="mobileMenuOverlay"
  class="mobile-menu-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="mobileMenuNavLabel"
  aria-hidden="true"
>
  <div class="mobile-menu-backdrop" id="mobileMenuBackdrop"></div>

  <div class="mobile-menu-panel" id="mobileMenuPanel">
    {# Header with logo and close button #}
    <div class="mobile-menu-header">
      <div class="mobile-menu-logo">
        <img
          src="/themes/custom/b5subtheme/images/logo-greyscale.svg"
          alt="{{ 'Home'|t }}"
        />
      </div>
      <button
        type="button"
        class="mobile-menu-close"
        id="mobileMenuClose"
        aria-label="{{ 'Close mobile menu'|t }}"
      >
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
    </div>

    {# Navigation Menu - Dynamically rendered from Drupal menu #}
    <nav class="mobile-menu-nav" aria-label="{{ 'Mobile navigation'|t }}">
      <h2 id="mobileMenuNavLabel" class="visually-hidden">{{ 'Main Menu'|t }}</h2>

      {% for item in mobile_menu_items %}
        <div class="mobile-nav-item">
          {% if item.below %}
            {# Item with submenu #}
            <div class="mobile-nav-link">
              <a href="{{ item.url }}" class="menu-text-link">{{ item.title }}</a>
              <button
                class="menu-toggle"
                aria-expanded="false"
                aria-controls="mobile-submenu-{{ loop.index }}"
                aria-label="{{ 'Toggle @title submenu'|t({'@title': item.title}) }}"
              >
                <i class="fa-solid fa-plus menu-icon" aria-hidden="true"></i>
              </button>
            </div>
            <div class="mobile-submenu" id="mobile-submenu-{{ loop.index }}">
              {% for child in item.below %}
                <div class="mobile-submenu-item">
                  <a href="{{ child.url }}" class="mobile-submenu-link">{{ child.title }}</a>
                </div>
              {% endfor %}
            </div>
          {% else %}
            {# Standalone item without submenu #}
            <a href="{{ item.url }}" class="mobile-nav-link no-submenu">
              <span class="menu-text">{{ item.title }}</span>
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </nav>

    {# Search Section #}
    <div class="mobile-menu-search">
      <form class="mobile-search-form" action="/search" method="get">
        <input
          type="search"
          name="keys"
          class="mobile-search-input"
          placeholder="{{ 'Search our site...'|t }}"
          aria-label="{{ 'Search'|t }}"
        />
        <button
          type="submit"
          class="mobile-search-button"
          aria-label="{{ 'Submit search'|t }}"
        >
          <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
        </button>
      </form>
    </div>
  </div>
</div>
