{#
/**
 * @file
 * Template for Press Room content type.
 *
 * Displays the main content followed by the filterable press entries listing.
 * Uses standard page layout with curved header and footer (handled by page.html.twig).
 *
 * Note: The reports_publications content type uses its own template
 * (node--reports-publications.html.twig), so no path-based view selection is needed here.
 *
 * Available variables:
 * - content: Rendered content fields
 * - attributes: HTML attributes for the article element
 * - node: The node entity
 */
#}

<article{{ attributes.addClass('node', 'node--press-room') }}>

  {# Main content - field template adds .content-body #}
  {% if content.field_main_content %}
    <div class="container">
      {{ content.field_main_content }}
    </div>
  {% endif %}

  {# Press Room Listing Section #}
  <section class="press-room-listing-section">
    <div class="container">
      {{ drupal_view('press_room_listing', 'block_1') }}
    </div>
  </section>

</article>
