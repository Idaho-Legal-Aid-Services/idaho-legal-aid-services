{#
/**
 * @file
 * Theme override for form item fields on the topic page.
 * Formats the title nicely (removes extension, title case).
 */
#}

{# Get the raw name and clean it up #}
{% set raw_name = fields.name.content|render|striptags|trim %}

{# Remove file extension and format as title case #}
{% set clean_name = raw_name|replace({'.pdf': '', '.doc': '', '.docx': '', '.xls': '', '.xlsx': '', '.txt': '', '.rtf': ''}) %}
{% set clean_name = clean_name|replace({'-': ' ', '_': ' '}) %}
{% set clean_name = clean_name|title %}

{# Title #}
<h3 class="form-item-title">{{ clean_name }}</h3>

{# Download link - extract URL from rendered field and create clean button #}
{% if fields.field_media_document is defined %}
  {% set rendered_field = fields.field_media_document.content|render|trim %}
  {# Extract href from the rendered anchor tag #}
  {% set href_match = rendered_field|replace({'<a href="': '###HREF###'})|split('###HREF###') %}
  {% if href_match|length > 1 %}
    {% set file_url = href_match[1]|split('"')[0] %}
    <div class="form-item-download">
      <a href="{{ file_url }}"
         class="form-item-download__btn"
         download
         target="_blank"
         rel="noopener noreferrer"
         title="Download {{ clean_name }}">
        <span class="form-item-download__text">DOWNLOAD FORM</span>
      </a>
    </div>
  {% else %}
    {# Fallback to original rendering if URL extraction fails #}
    <div class="form-item-download">
      {{ fields.field_media_document.content }}
    </div>
  {% endif %}
{% endif %}

{# Last updated #}
{% if fields.changed is defined %}
  <div class="form-item-meta">
    <span class="form-item-label">Last updated:</span>
    <span class="form-item-updated">{{ fields.changed.content|render|striptags|trim }}</span>
  </div>
{% endif %}
