{#
/**
 * @file
 * Theme override for resources by service view.
 * Combines navigation and resources display.
 */
#}

{{ attach_library('b5subtheme/resources') }}

<div{{ attributes.addClass('view', 'resources-view') }}>

  {# Curved page header - only for page display, not embedded blocks #}
  {% if view.current_display starts with 'page' %}
    <section class="curved-page-header resources-curved-header">
      <div class="container">
        <h1 class="curved-page-header-title">{{ view.getTitle() ?: 'Resources' }}</h1>
      </div>
    </section>
  {% endif %}

  {# Filter pills will be generated by JavaScript #}
  <div class="resource-filters mb-4">
    <ul class="nav nav-pills flex-wrap gap-2">
      <li class="nav-item">
        <button class="nav-link pill-link active" data-filter="all">
          All Topics
        </button>
      </li>
    </ul>
  </div>
  
  {% if header %}
    <div class="view-header">
      {{ header }}
    </div>
  {% endif %}
  
  {% if exposed %}
    <div class="view-filters">
      {{ exposed }}
    </div>
  {% endif %}
  
  {% if attachment_before %}
    <div class="attachment attachment-before">
      {{ attachment_before }}
    </div>
  {% endif %}
  
  {% if rows %}
    <div class="view-content">
      {{ rows }}
    </div>
  {% elseif empty %}
    <div class="view-empty">
      {{ empty }}
    </div>
  {% endif %}
  
  {% if pager %}
    {{ pager }}
  {% endif %}
  
  {% if attachment_after %}
    <div class="attachment attachment-after">
      {{ attachment_after }}
    </div>
  {% endif %}
  
  {% if more %}
    {{ more }}
  {% endif %}
  
  {% if footer %}
    <div class="view-footer">
      {{ footer }}
    </div>
  {% endif %}
  
  {% if feed_icons %}
    <div class="feed-icons">
      {{ feed_icons }}
    </div>
  {% endif %}
</div>