{#
/**
 * @file
 * Theme override for the Forms landing page view.
 * Displays form categories as clickable cards with curved header.
 * Includes topic navigation dropdown for quick access to specific topics.
 */
#}

{{ attach_library('b5subtheme/forms') }}

<div{{ attributes.addClass('view', 'forms-view', 'forms-landing') }}>

  {# Curved page header matching site style #}
  <section class="curved-page-header forms-curved-header">
    <div class="container">
      <h1 class="curved-page-header-title">Forms & Documents</h1>
    </div>
  </section>

  {# Intro text below curved header #}
  {% if header %}
    <div class="forms-intro-section">
      <div class="container">
        <div class="forms-intro">
          {{ header }}
        </div>
      </div>
    </div>
  {% endif %}

  {# Topic navigation filter - between intro and content #}
  {% if topic_nav_options is not empty %}
    <div class="forms-filter-section">
      <div class="container">
        <div class="forms-filter">
          <div class="forms-filter__inner">
            <div class="forms-filter__select">
              <label for="{{ topic_nav_id }}">{{ topic_nav_label }}</label>
              <select id="{{ topic_nav_id }}" class="forms-filter__dropdown" data-base-path="{{ topic_nav_base_path }}">
                <option value="">{{ 'Select a topic...'|t }}</option>
                {% for option in topic_nav_options %}
                  <option value="{{ option.url_slug }}">{{ option.name }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="forms-filter__actions">
              <button type="button" class="forms-filter__button" id="{{ topic_nav_id }}-go">
                {{ 'Go'|t }}
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  {# Category cards grid #}
  <div class="forms-content">
    <div class="container">
      <div class="forms-main-content">
        {% if rows %}
          <div class="forms-category-grid" role="list" aria-label="Form categories">
            {{ rows }}
          </div>
        {% elseif empty %}
          <div class="forms-empty-state">
            {{ empty }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {% if pager %}
    <div class="forms-pager">
      <div class="container">
        {{ pager }}
      </div>
    </div>
  {% endif %}

  {% if footer %}
    <div class="forms-footer">
      <div class="container">
        {{ footer }}
      </div>
    </div>
  {% endif %}
</div>
