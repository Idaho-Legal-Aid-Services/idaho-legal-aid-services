# ILAS Environment Variables
# Copy this file to .env and configure values for your environment.
#
# Note: These environment variables provide the most secure way to store
# sensitive API keys. They take precedence over database configuration values.

# SMTP (Symfony Mailer Lite transport password)
# SMTP_PASSWORD=

# Cloudflare Turnstile CAPTCHA keys
# Get these from https://dash.cloudflare.com/ → Turnstile
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# TMGMT Google Translate API key
# Get from https://console.cloud.google.com/ → APIs & Services → Credentials
# TMGMT_GOOGLE_API_KEY=